{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@/*": ["src/*"],
      "@photos/*": ["photos/*"]
    }
  },
  "include": ["src", "**/*.astro", ".astro/types.d.ts", "astro.config.mjs"],
  "exclude": ["node_modules", "dist"]
}
