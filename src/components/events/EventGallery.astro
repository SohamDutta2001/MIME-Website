---
// Event photo gallery — polaroids scattered on the page, opened full-size
// by the GalleryLightbox island (it listens for clicks on
// [data-gallery-index] anywhere in the document).
import GalleryLightbox from '~/components/islands/GalleryLightbox.tsx';
import { resolveEventImage } from '~/lib/events/images.js';
import type { CafeEvent } from '~/types/event';

interface Props {
  event: CafeEvent;
}

const { event } = Astro.props;
const photos = event.galleryUrls.map((url, i) => ({
  thumb: resolveEventImage(url, { width: 700 }),
  full: resolveEventImage(url, { width: 1800 }),
  alt: `${event.title} — photograph ${i + 1}`,
}));
const tilts = [-2, 1.5, -1, 2.2, -1.8, 0.8];
---

{photos.length > 0 && (
  <section aria-label="Event photographs">
    <p class="font-hand text-2xl text-tea-500">from the camera roll</p>
    <h2 class="mt-2 font-serif text-display-md font-medium text-tea-900">
      The room, mid-moment.
    </h2>

    <div class="mt-10 grid grid-cols-2 gap-5 sm:grid-cols-3 sm:gap-8">
      {photos.map((photo, i) => (
        <button
          type="button"
          data-gallery-index={i}
          aria-label={`Open ${photo.alt}`}
          class="group bg-cream p-2.5 pb-8 text-left shadow-polaroid transition-transform duration-300 ease-ink hover:rotate-0 hover:scale-[1.03] sm:p-3 sm:pb-10"
          style={`transform: rotate(${tilts[i % tilts.length]}deg);`}
        >
          <img
            src={photo.thumb}
            alt={photo.alt}
            loading="lazy"
            class="aspect-[4/3] w-full object-cover sepia-[0.25] transition-all duration-500 group-hover:sepia-0"
          />
          <span class="mt-2 block px-1 font-hand text-sm text-tea-600">№ {i + 1}</span>
        </button>
      ))}
    </div>

    <GalleryLightbox client:load photos={photos.map((p) => ({ src: p.full, alt: p.alt }))} />
  </section>
)}
