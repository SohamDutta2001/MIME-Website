---
import { navLinks, site } from '~/data/site';

const base = import.meta.env.BASE_URL;
const basePath = base === '/' ? '' : base.replace(/\/$/, '');
const withBase = (path: string) => `${basePath}${path}`;
const path = Astro.url.pathname
  .replace(basePath, '')
  .replace(/\/$/, '') || '/';
---

<header class="border-b border-tea-500/15 bg-cream/40 backdrop-blur-[2px]">
  <nav
    class="mx-auto flex max-w-editorial flex-col gap-2.5 px-gutter py-4 md:flex-row md:items-center md:justify-between md:py-5"
    aria-label="Primary"
  >
    <a href={withBase('/')} class="group flex items-baseline gap-2 transition-opacity hover:opacity-80">
      <span class="whitespace-nowrap font-serif text-xl font-semibold tracking-tight text-tea-900 sm:text-2xl">
        {site.name}
      </span>
      <span class="hidden font-hand text-base text-tea-600 sm:inline">— {site.accent}</span>
    </a>
    <ul class="-mx-1.5 flex flex-wrap items-center gap-1 text-sm md:mx-0 md:gap-2">
      {navLinks.map(link => {
        const isActive = path === link.href || (link.href !== '/' && path.startsWith(link.href));
        return (
          <li>
            <a
              href={withBase(link.href)}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'nav-pill',
                isActive
                  ? 'bg-tea-700 text-cream'
                  : 'text-tea-700 hover:bg-tea-500/10 hover:text-tea-900',
              ]}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
