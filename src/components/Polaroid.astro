---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  rotate?: number;
  tape?: 'top' | 'corner' | 'none';
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  caption,
  rotate = 0,
  tape = 'top',
  width = 600,
  height = 750,
  class: extraClass = '',
  loading = 'lazy',
} = Astro.props;

const transform = rotate !== 0 ? `rotate(${rotate}deg)` : undefined;
---

<figure
  class:list={['polaroid relative inline-block bg-cream p-3 pb-12 shadow-polaroid transition-transform duration-300 ease-ink hover:rotate-0 hover:scale-[1.02]', extraClass]}
  style={transform ? `--rotate: ${rotate}deg; transform: ${transform};` : undefined}
>
  {tape === 'top' && (
    <span aria-hidden="true" class="absolute -top-3 left-1/2 h-6 w-20 -translate-x-1/2 -rotate-2 bg-tea-300/55 mix-blend-multiply" />
  )}
  {tape === 'corner' && (
    <span aria-hidden="true" class="absolute -left-3 -top-3 h-6 w-16 -rotate-12 bg-tea-300/55 mix-blend-multiply" />
  )}
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    class="block h-auto w-full select-none"
    style="filter: sepia(0.05) saturate(0.95);"
  />
  {caption && (
    <figcaption class="absolute inset-x-3 bottom-3 text-center font-hand text-base text-tea-700">
      {caption}
    </figcaption>
  )}
</figure>
