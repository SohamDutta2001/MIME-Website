---
import { ViewTransitions } from 'astro:transitions';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import { site } from '~/data/site';
import '~/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  variant?: 'default' | 'wide';
}

const { title, description, variant = 'default' } = Astro.props;
const fullTitle = title ? `${title} — ${site.name}` : site.name;
const meta = description ?? site.description;
const assetBase = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={meta} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#3b2418" />
    <ViewTransitions />
  </head>
  <body class="grain-overlay">
    <Nav />
    <main class:list={['mx-auto', variant === 'wide' ? 'max-w-editorial' : 'max-w-column', 'px-gutter']}>
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll dynamics for the Astro-rendered pages (event pages, menu,
      // adda…). Two opt-in attributes:
      //   data-reveal            — fades/settles in when scrolled into view
      //                            (stagger with style="--reveal-delay: …")
      //   data-parallax="0.12"   — drifts against the scroll by that factor
      //                            (use on images inside overflow-hidden)
      // Both honour prefers-reduced-motion and re-bind after ViewTransitions.
      let controller: AbortController | undefined;

      function initScrollDynamics() {
        // Tear down the previous page's listeners after a ViewTransitions
        // swap (also makes the initial double-fire harmless).
        controller?.abort();
        controller = new AbortController();
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const revealEls = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
        if (revealEls.length) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (!entry.isIntersecting) continue;
                entry.target.classList.add('revealed');
                io.unobserve(entry.target);
              }
            },
            { rootMargin: '0px 0px -64px 0px', threshold: 0.05 },
          );
          for (const el of revealEls) {
            el.classList.add('reveal');
            io.observe(el);
          }
        }

        const parallaxEls = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
        if (parallaxEls.length) {
          let ticking = false;
          const update = () => {
            ticking = false;
            for (const el of parallaxEls) {
              const factor = Number(el.dataset.parallax) || 0.1;
              const box = (el.parentElement ?? el).getBoundingClientRect();
              const offset = box.top + box.height / 2 - window.innerHeight / 2;
              // Scale slightly so the drifting image never shows its edges.
              el.style.transform = `translateY(${(-offset * factor).toFixed(1)}px) scale(1.12)`;
            }
          };
          const onScroll = () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(update);
          };
          update();
          window.addEventListener('scroll', onScroll, { passive: true, signal: controller.signal });
        }
      }

      initScrollDynamics();
      document.addEventListener('astro:page-load', initScrollDynamics);
    </script>
  </body>
</html>
