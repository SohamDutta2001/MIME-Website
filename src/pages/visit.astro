---
import { Image } from 'astro:assets';
import Layout from '~/components/Layout.astro';
import Section from '~/components/Section.astro';
import { site } from '~/data/site';
import { photos } from '~/data/photos';
---

<Layout title="Visit" description="Location, hours, and the door at 14B College Street.">
  <header class="pt-12 sm:pt-16">
    <p class="font-hand text-lg text-tea-500">end of magazine</p>
    <h1 class="mt-2 text-balance font-serif text-display-xl font-medium text-tea-900">Find Us</h1>
    <p class="mt-6 max-w-prose font-body text-lg leading-relaxed text-tea-700">
      We are on College Street, where College Street is most itself. The blue door
      with the small hand-painted sign. Above the bookshop. You'll know.
    </p>
  </header>

  <div class="ink-divider mt-16" aria-hidden="true" />

  <Section>
    <div class="grid gap-12 md:grid-cols-2 md:gap-16">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-tea-500">Address</p>
        <p class="mt-3 font-serif text-2xl text-tea-900">{site.location.line1}</p>
        <p class="font-serif text-xl text-tea-800">{site.location.line2}</p>
        <p class="mt-3 max-w-prose font-hand text-base text-tea-500">{site.location.note}</p>

        <div class="mt-10">
          <p class="text-xs uppercase tracking-[0.22em] text-tea-500">Hours</p>
          <ul class="mt-3 max-w-sm space-y-1.5 font-body text-tea-800">
            {site.hours.map(({ days, time }) => (
              <li class="flex items-baseline justify-between gap-6 border-b border-tea-500/15 pb-1.5">
                <span>{days}</span>
                <span class="tabular-nums">{time}</span>
              </li>
            ))}
          </ul>
          <p class="mt-4 font-hand text-base text-tea-500">
            We do not have a closing announcement. If the kettle is on, we are open.
          </p>
        </div>
      </div>

      <div class="-mx-4 sm:mx-0">
        <Image
          src={photos.mapSketch}
          alt="A hand-drawn map showing the cafe's location on College Street"
          width={800}
          height={600}
          class="h-auto w-full"
        />
      </div>
    </div>
  </Section>

  <div class="ink-divider" aria-hidden="true" />

  <Section heading="Say hello">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-tea-500">Phone</p>
        <p class="mt-2 font-body text-lg text-tea-900 tabular-nums">{site.contact.phone}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-tea-500">Email</p>
        <p class="mt-2 font-body text-lg">
          <a href={`mailto:${site.contact.email}`} class="ink-link">{site.contact.email}</a>
        </p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-tea-500">Instagram</p>
        <p class="mt-2 font-body text-lg">
          <a href={site.contact.instagramUrl} target="_blank" rel="noopener" class="ink-link">{site.contact.instagram}</a>
        </p>
      </div>
    </div>
  </Section>

  <div class="ink-divider" aria-hidden="true" />

  <Section align="center">
    <p class="mx-auto max-w-prose font-body italic leading-relaxed text-tea-700">
      We share a long shared lineage with the {site.affiliation.name}. Many of our
      regulars came in through that door first. {site.affiliation.note}
    </p>
    <Image src={photos.signature} alt="" width={140} height={42} class="mx-auto mt-12 opacity-70" />
    <p class="mt-4 font-hand text-base text-tea-500">{site.bengali.closing}</p>
  </Section>
</Layout>
