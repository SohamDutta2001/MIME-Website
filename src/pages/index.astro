---
import { Image } from 'astro:assets';
import Layout from '~/components/Layout.astro';
import Section from '~/components/Section.astro';
import Polaroid from '~/components/Polaroid.astro';
import PullQuote from '~/components/PullQuote.astro';
import { site } from '~/data/site';
import { photos } from '~/data/photos';
---

<Layout description={site.description}>
  {/* HERO — image-led, large emotional landing */}
  <section class="relative -mx-gutter mt-2 overflow-hidden" transition:name="hero">
    <div class="relative w-full min-h-[78svh] sm:min-h-[82svh] lg:min-h-0 lg:aspect-[16/7]">
      <Image
        src={photos.hero}
        alt="The cafe at golden hour, light through the windows, an open notebook on a wooden table"
        width={1600}
        height={900}
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-tea-900/75 via-tea-900/25 to-tea-900/10" />
      <div class="absolute inset-0 flex flex-col items-center justify-end px-gutter pb-12 pt-8 text-center sm:pb-20 sm:pt-12">
        <p class="font-hand text-xl text-amber sm:text-2xl">{site.accent}</p>
        <h1 class="mt-4 text-balance font-serif text-display-xl font-medium text-cream drop-shadow-md sm:text-display-2xl">
          {site.tagline}
        </h1>
        <p class="mt-6 max-w-prose font-body text-base leading-relaxed text-cream/85 sm:text-lg">
          A Kolkata café reimagining the roadside cha er dokan as an artistic social space.
          Adda, books, tea, slow hours.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a href="/visit" class="rounded-full bg-cream px-6 py-3 font-body text-sm font-medium tracking-wide text-tea-900 shadow-soft transition-transform hover:scale-[1.02]">Visit Us</a>
          <a href="/menu" class="rounded-full border border-cream/45 px-6 py-3 font-body text-sm font-medium tracking-wide text-cream transition-colors hover:bg-cream/10">See the Menu</a>
        </div>
      </div>
    </div>
  </section>

  {/* PHILOSOPHY EXCERPT */}
  <Section accent="A small manifesto">
    <div class="grid gap-10 md:grid-cols-3 md:gap-12">
      <div class="md:col-span-2">
        <p class="font-serif text-2xl leading-relaxed text-tea-900 sm:text-3xl">
          We grew up watching our parents and grandparents linger over a clay cup of cha,
          shoulders brushing strangers, arguing the day into shape. Then the cups got
          paper. The arguments moved to phones. The strangers stopped speaking.
        </p>
        <p class="mt-6 max-w-prose font-body leading-loose text-tea-700">
          Art Teas Tree is a small protest against that. A tea stall, reimagined with
          chairs that don't ask you to leave. Books that don't belong to anyone. Light
          warm enough to keep reading. A philosophy held in one line:
        </p>
        <p class="mt-6 font-hand text-2xl text-tea-900">
          {site.philosophy}
        </p>
      </div>
      <aside class="flex items-start justify-center md:justify-end">
        <Polaroid
          src={photos.experience.cha}
          alt="A clay cup of cha cooling on a wooden ledge"
          caption="the first cup of the evening"
          rotate={-2}
          tape="corner"
          width={360}
          height={450}
          loading="lazy"
        />
      </aside>
    </div>
  </Section>

  {/* THREE TEASER CARDS */}
  <Section heading="What you'll find here" divider align="center">
    <div class="grid gap-10 md:grid-cols-3">
      {[
        { href: '/experience', title: 'The Experience', body: 'On adda, books, smoke, and the slow hours that make a place a place.', photo: photos.experience.books, caption: 'the bookshelf, late afternoon' },
        { href: '/menu', title: 'The Menu', body: 'Tea pulled slow. Coffee from south filter beans. Snacks worth pausing for.', photo: photos.experience.smoke, caption: 'the small kettle' },
        { href: '/adda', title: 'Adda', body: 'A gallery and a few notes from the regulars. The room when nobody is looking.', photo: photos.experience.hours, caption: 'a corner table at dusk' },
      ].map(card => (
        <a href={card.href} class="group flex flex-col items-center text-center transition-transform duration-300 hover:-translate-y-1">
          <Polaroid src={card.photo} alt={card.caption} caption={card.caption} rotate={(Math.random() * 4 - 2)} width={400} height={500} />
          <h3 class="mt-8 font-serif text-2xl font-medium text-tea-900">{card.title}</h3>
          <p class="mt-2 max-w-[20rem] font-body text-tea-700">{card.body}</p>
          <span class="mt-3 font-hand text-base text-tea-500 group-hover:text-tea-700">read on →</span>
        </a>
      ))}
    </div>
  </Section>

  {/* CLOSING BENGALI PULLQUOTE */}
  <PullQuote lang="bn" size="xl">{site.bengali.adda}</PullQuote>
  <p class="-mt-12 text-center font-hand text-base text-tea-500">
    adda — the slow, unfinished art of being together.
  </p>
</Layout>
