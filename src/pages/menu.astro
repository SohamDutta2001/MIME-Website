---
import Layout from '~/components/Layout.astro';
import Section from '~/components/Section.astro';
import MenuCard from '~/components/MenuCard.astro';
import MenuFilter from '~/components/islands/MenuFilter.tsx';
import menuRows from '~/data/mockMenuData.json';

// Derive unique categories in the order they first appear in the sheet.
// This means the café owner adds a new category by simply adding rows —
// no code change needed.
const categories: string[] = [];
for (const row of menuRows) {
  if (!categories.includes(row.category)) categories.push(row.category);
}

// Group rows by category, preserving sheet order within each group.
const grouped = new Map<string, typeof menuRows>();
for (const row of menuRows) {
  if (!grouped.has(row.category)) grouped.set(row.category, []);
  grouped.get(row.category)!.push(row);
}

const rotateFor = (i: number) => ((i % 5) - 2) * 0.5;
---

<Layout title="Menu" description="Tea pulled slow. Coffee from south filter beans. Snacks worth pausing for.">
  <header class="pt-12 sm:pt-16">
    <p class="font-hand text-lg text-tea-500">A tea-stained page</p>
    <h1 class="mt-2 text-balance font-serif text-display-xl font-medium text-tea-900">The Menu</h1>
    <p class="mt-6 max-w-prose font-body text-lg leading-relaxed text-tea-700">
      Everything here is made slow. Tea is steeped, not steamed. Coffee is pulled, not poured.
      Snacks come out when they're done, not when you ordered.
    </p>
  </header>

  {menuRows.length > 0 && (
    <div class="mt-10">
      <MenuFilter categories={categories} client:visible />
    </div>
  )}

  <div class="ink-divider mt-16" aria-hidden="true" />

  {categories.length === 0 ? (
    <Section>
      <p class="font-hand text-2xl text-tea-500 text-center py-12">
        Nothing on the menu yet — ask us what's brewing.
      </p>
    </Section>
  ) : categories.map(cat => {
    const items = grouped.get(cat) ?? [];
    return (
      <Section id={cat.toLowerCase().replace(/\s+/g, '-')}>
        <header class="mb-8 max-w-prose">
          <h2 class="font-serif text-display-md font-medium text-tea-900">{cat}</h2>
        </header>
        <div class="grid gap-5 sm:grid-cols-2 md:gap-6">
          {items.map((item, i) => (
            <MenuCard
              name={item.itemName}
              price={item.price}
              description={item.description}
              category={item.category}
              rotate={rotateFor(i)}
            />
          ))}
        </div>
      </Section>
    );
  })}

  <Section align="center" divider>
    <p class="mx-auto max-w-prose font-body text-tea-700">
      Prices are in rupees, inclusive of tax. We accept cash, cards, and UPI.
      A small bowl of nimki appears at every table on its own.
    </p>
  </Section>
</Layout>
