---
// Template engine: category → template component. Every event page is one
// of the three category templates wrapped around BaseEventLayout.
import PerformanceTemplate from '~/components/events/templates/PerformanceTemplate.astro';
import WorkshopTemplate from '~/components/events/templates/WorkshopTemplate.astro';
import ExhibitionTemplate from '~/components/events/templates/ExhibitionTemplate.astro';
import { allEvents } from '~/lib/events/events';
import type { CafeEvent } from '~/types/event';

export function getStaticPaths() {
  return allEvents.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

interface Props {
  event: CafeEvent;
}

const { event } = Astro.props;

const templates = {
  Performance: PerformanceTemplate,
  Workshop: WorkshopTemplate,
  Exhibition: ExhibitionTemplate,
} as const;

const Template = templates[event.category];
---

<Template event={event} />
