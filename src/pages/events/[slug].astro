---
import BaseEventLayout from '~/components/events/BaseEventLayout.astro';
import { allEvents } from '~/lib/events/events';
import type { CafeEvent } from '~/types/event';

export function getStaticPaths() {
  return allEvents.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

interface Props {
  event: CafeEvent;
}

const { event } = Astro.props;
---

<BaseEventLayout event={event} kicker={event.category} kickerBn="অনুষ্ঠান" />
